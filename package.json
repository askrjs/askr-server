{
  "name": "@askrjs/server",
  "version": "0.0.3",
  "description": "Transport-neutral HTTP application core built on Web Request and Response",
  "keywords": [
    "askr",
    "http",
    "openapi",
    "server"
  ],
  "homepage": "https://github.com/askrjs/askr-server#readme",
  "bugs": {
    "url": "https://github.com/askrjs/askr-server/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "askrjs",
    "url": "https://github.com/askrjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/askrjs/askr-server.git"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./router": {
      "types": "./dist/router.d.ts",
      "import": "./dist/router.js"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js"
    },
    "./askr": {
      "types": "./dist/askr.d.ts",
      "import": "./dist/askr.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    },
    "./openapi": {
      "types": "./dist/openapi.d.ts",
      "import": "./dist/openapi.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "bench": "npm run bench:dispatch && npm run bench:binding && npm run bench:tier1 && npm run bench:tier2 && npm run bench:tier3 && npm run bench:tier4",
    "bench:binding": "vp test bench --run --reporter=default benches/binding.bench.ts",
    "bench:dispatch": "vp test bench --run --reporter=default benches/request-dispatch.bench.ts",
    "bench:tier1": "vp test bench --run --reporter=default --config vitest.bench.tier1.config.ts",
    "bench:tier2": "vp test bench --run --reporter=default --config vitest.bench.tier2.config.ts",
    "bench:tier3": "vp test bench --run --reporter=default --config vitest.bench.tier3.config.ts",
    "bench:tier4": "vp test bench --run --reporter=default --config vitest.bench.tier4.config.ts",
    "fmt": "vp fmt .",
    "lint": "vp lint src tests benches vite.config.ts vitest.*.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run test:unit && npm run test:checks",
    "test:unit": "vp test run -c vitest.test.unit.config.ts",
    "test:checks": "npm run typecheck && npm run test:types",
    "test:types": "npm run build && tsc -p tests/types/tsconfig.json",
    "test:publint": "publint",
    "pack:check": "node tests/package-artifacts.js",
    "check": "npm run lint && npm run typecheck && npm test && npm run build && npm run test:publint && npm run pack:check",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "@askrjs/auth": ">=0.0.1 <0.1.0",
    "@askrjs/schema": ">=0.0.1 <0.1.0"
  },
  "devDependencies": {
    "@askrjs/askr": ">=0.0.52 <0.1.0",
    "publint": "^0.3.12",
    "typescript": "^6.0.0",
    "vite-plus": "^0.2.4",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "@askrjs/askr": ">=0.0.52 <0.1.0"
  },
  "peerDependenciesMeta": {
    "@askrjs/askr": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
